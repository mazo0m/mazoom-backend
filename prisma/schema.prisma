generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// Registered users — either platform admins or clients who create invitations.
model User {
  id               String            @id @default(uuid()) @db.Uuid
  email            String            @unique
  passwordHash     String?           @map("password_hash")
  role             Role              @default(CLIENT)
  createdAt        DateTime          @default(now()) @map("created_at")
  firstName        String            @map("first_name")
  lastName         String            @map("last_name")
  phoneNumber      String?           @unique @map("phone_number")
  isActive         Boolean           @default(true) @map("is_active")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  purchaseRequests PurchaseRequest[]
  purchases        Purchase[]
  refreshTokens    RefreshToken[]

  @@map("users")
}

/// Invitation design templates managed by admins.
/// Clients browse and select a template to build their invitation.
model Template {
  id               String            @id @default(uuid()) @db.Uuid
  title            String
  demoLink         String?           @map("demo_link")
  price            Decimal           @db.Decimal(10, 2)
  isPremium        Boolean           @default(false) @map("is_premium")
  createdAt        DateTime          @default(now()) @map("created_at")
  category         TemplateCategory  @default(Weddings)
  description      String
  descriptionAr    String?           @map("description_ar")
  descriptionEn    String?           @map("description_en")
  editableFields   Json              @map("editable_fields")
  isActive         Boolean           @default(true) @map("is_active")
  previewImage     String            @map("preview_image")
  titleAr          String?           @map("title_ar")
  titleEn          String?           @map("title_en")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  purchaseRequests PurchaseRequest[]
  purchases        Purchase[]

  @@index([isActive])
  @@index([category])
  @@map("templates")
}

/// Purchase / unlock requests — tracks when a client requests access
/// to a template.
model PurchaseRequest {
  id           String        @id @default(uuid()) @db.Uuid
  userId       String        @map("user_id") @db.Uuid
  templateId   String        @map("template_id") @db.Uuid
  contactEmail String        @map("contact_email")
  contactPhone String        @map("contact_phone")
  languageMode String        @default("both") @map("language_mode")
  status       RequestStatus @default(PENDING)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  template     Template      @relation(fields: [templateId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  purchase     Purchase?

  @@index([userId])
  @@index([templateId])
  @@index([status])
  @@index([userId, status])
  @@map("purchase_requests")
}

/// A purchase record created when a PurchaseRequest is approved.
model Purchase {
  id                String          @id @default(uuid()) @db.Uuid
  userId            String          @map("user_id") @db.Uuid
  templateId        String          @map("template_id") @db.Uuid
  purchaseRequestId String          @unique @map("purchase_request_id") @db.Uuid
  slug              String          @unique
  languageMode      String          @default("both") @map("language_mode")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  invitation        Invitation?
  purchaseRequest   PurchaseRequest @relation(fields: [purchaseRequestId], references: [id], onDelete: Cascade)
  template          Template        @relation(fields: [templateId], references: [id], onDelete: Cascade)
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  testimonial       Testimonial?

  @@index([userId])
  @@index([templateId])
  @@map("purchases")
}

/// A published digital invitation created by a client using a chosen template purchase.
model Invitation {
  id                String   @id @default(uuid()) @db.Uuid
  slug              String   @unique
  eventDate         DateTime @map("event_date")
  locationUrl       String?  @map("location_url")
  welcomeText       String?  @map("welcome_text")
  images            String[]
  musicUrl          String?  @map("music_url")
  createdAt         DateTime @default(now()) @map("created_at")
  allowGuestUploads Boolean  @default(true) @map("allow_guest_uploads")
  showMoments       Boolean  @default(true) @map("show_moments")
  allowCompanions   Boolean  @default(true) @map("allow_companions")
  contactName       String?  @map("contact_name")
  contactPhone      String?  @map("contact_phone")
  eventDetails      Json[]   @default([]) @map("event_details")
  eventLocation     String   @map("event_location")
  eventLocationAr   String?  @map("event_location_ar")
  eventLocationEn   String?  @map("event_location_en")
  eventProgram      Json[]   @default([]) @map("event_program")
  eventTitle        String   @map("event_title")
  eventTitleAr      String?  @map("event_title_ar")
  eventTitleEn      String?  @map("event_title_en")
  isActive          Boolean  @default(true) @map("is_active")
  languageMode      String   @default("both") @map("language_mode")
  moments           String[] @default([])
  hiddenMoments     String[] @default([]) @map("hidden_moments")
  deletedMoments    String[] @default([]) @map("deleted_moments")
  deletedImages     String[] @default([]) @map("deleted_images")
  galleryOrder      String[] @default([]) @map("gallery_order")
  purchaseId        String   @unique @map("purchase_id") @db.Uuid
  updatedAt         DateTime @updatedAt @map("updated_at")
  welcomeTextAr     String?  @map("welcome_text_ar")
  welcomeTextEn     String?  @map("welcome_text_en")
  purchase          Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  rsvps             RSVP[]

  @@index([purchaseId])
  @@index([slug])
  @@index([isActive])
  @@map("invitations")
}

/// Guest RSVP responses linked to a specific invitation.
model RSVP {
  id           String         @id @default(uuid()) @db.Uuid
  invitationId String         @map("invitation_id") @db.Uuid
  createdAt    DateTime       @default(now()) @map("created_at")
  attendance   RsvpAttendance
  guestsCount  Int            @default(0) @map("guests_count")
  message      String?
  name         String
  isDeleted    Boolean        @default(false) @map("is_deleted")
  isHidden     Boolean        @default(false) @map("is_hidden")
  invitation   Invitation     @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  @@index([invitationId])
  @@map("rsvps")
}

/// Client testimonials / reviews for templates/services
model Testimonial {
  id         String   @id @default(uuid()) @db.Uuid
  purchaseId String   @unique @map("purchase_id") @db.Uuid
  rating     Int
  comment    String
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  isDeleted  Boolean  @default(false) @map("is_deleted")
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  @@index([isDeleted])
  @@map("testimonials")
}

/// Refresh tokens for tracking user sessions and token rotation.
model RefreshToken {
  id            String    @id @default(uuid()) @db.Uuid
  tokenHash     String    @unique @map("token_hash")
  userId        String    @map("user_id") @db.Uuid
  expiresAt     DateTime  @map("expires_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  isRevoked     Boolean   @default(false) @map("is_revoked")
  replacedBy    String?   @map("replaced_by")
  revokedAt     DateTime? @map("revoked_at")
  revokedReason String?   @map("revoked_reason")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

/// Durable audit logs for tracking security-sensitive actions.
model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  action    String
  ip        String?
  userAgent String?  @map("user_agent")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}

enum Role {
  ADMIN
  CLIENT
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum RsvpAttendance {
  YES
  NO
}

enum TemplateCategory {
  Weddings          @map("Weddings")
  BridalShowers     @map("Bridal Showers")
  EngagementParties @map("Engagement Parties")
  Birthdays         @map("Birthdays")
  CorporateEvents   @map("Corporate Events")
}

enum RefreshTokenRevokeReason {
  ROTATED
  LOGOUT
  REUSE_ATTEMPT
}

enum MediaType {
  IMAGE
  VIDEO
  AUDIO
}

model Media {
  id        String    @id @default(uuid()) @db.Uuid
  url       String
  key       String    @unique
  type      MediaType
  mimeType  String    @map("mime_type")
  size      Int       // Size in bytes
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("media")
}

